# =============================================================================
# Pulse AI - example environment file
# -----------------------------------------------------------------------------
# Copy this file to `.env` (which is git-ignored) and fill in real values.
# Settings are read by django-environ in config/settings/base.py and
# config/settings/production.py. Variables WITHOUT a default in the settings
# are required and will raise on startup if missing (noted as "required" below).
# =============================================================================

# --- Django core ---------------------------------------------------------------
# Toggle reading of this .env file (default: True).
DJANGO_READ_DOT_ENV_FILE=True
# Enable debug mode for local development. Never enable in production.
DJANGO_DEBUG=True
# Required in production (config/settings/production.py). Generate a long random
# string, e.g. `python -c "import secrets; print(secrets.token_urlsafe(64))"`.
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
# Selects the Django settings module used to run the project, e.g.
#   config.settings.base        (local development)
#   config.settings.production  (production)
DJANGO_SETTINGS_MODULE=config.settings.base
# Comma-separated hosts/domains Django will serve (production; required there
# since it no longer defaults to "*"). e.g. example.com,api.example.com
DJANGO_ALLOWED_HOSTS=

# --- Security (production) -----------------------------------------------------
# Comma-separated list of origins allowed to call the API cross-origin
# (CORS is no longer open to all). e.g. https://app.example.com
CORS_ALLOWED_ORIGINS=
# Redirect all HTTP traffic to HTTPS in production (default: True).
DJANGO_SECURE_SSL_REDIRECT=True

# --- Database (PostgreSQL) -----------------------------------------------------
# django-environ DATABASE_URL. Defaults to `postgres:///pulse_ai` if unset.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pulse_ai
# Persistent DB connection lifetime in seconds (production only, default: 60).
CONN_MAX_AGE=60

# --- AWS S3 (media & static storage via django-storages) -----------------------
# Required (no defaults in base settings) - the app uses S3 for uploaded audio,
# transcripts, summaries and profile pictures, and serves presigned URLs.
S3_AWS_ACCESS_KEY_ID=
S3_AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
# Optional S3 tuning.
DJANGO_AWS_S3_REGION_NAME=
DJANGO_AWS_S3_CUSTOM_DOMAIN=
DJANGO_AWS_S3_MAX_MEMORY_SIZE=100000000

# --- AWS SQS (async transcription/summarization worker) ------------------------
# The API enqueues a "speech-to-text" job on session upload. An external worker
# (not in this repo) consumes the queue, transcribes + summarizes the audio, and
# POSTs results back to /session-data/<session_id>/.
AWS_REGION=
SQS_URL=
SQS_AWS_ACCESS_KEY_ID=
SQS_AWS_SECRET_ACCESS_KEY=
# Credentials the worker uses to read the audio object from S3.
FUNCTION_QUEUE_AWS_S3_AWS_ACCESS_KEY_ID=
FUNCTION_QUEUE_AWS_S3_AWS_SECRET_ACCESS_KEY=

# Shared secret (sent as the `X-API-KEY` header) that authenticates the worker's
# callback to /session-data/<session_id>/.
THERAPIST_SESSION_POST_API_KEY=

# --- Auth / registration -------------------------------------------------------
ACCOUNT_ALLOW_REGISTRATION=True
# Force the admin sign-in through the django-allauth flow (default: False).
DJANGO_ADMIN_FORCE_ALLAUTH=False

# --- Email (production) --------------------------------------------------------
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=pulse-ai <noreply@example.com>
DJANGO_SERVER_EMAIL=
DJANGO_EMAIL_SUBJECT_PREFIX=[pulse-ai]

# --- Redis (optional cache; django-redis is installed) -------------------------
# REDIS_URL=redis://localhost:6379/0
